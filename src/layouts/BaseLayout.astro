---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getLangFromUrl } from '@/i18n/ui';
import { site } from '@/config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}
const { title, description, image = '/og-default.png', type = 'website' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const fullTitle = title ? `${title} · ${site.name}` : `${site.name} — ${site.domain}`;
const desc =
  description ??
  (lang === 'en'
    ? 'Vu AI — technology enthusiast. Blog, AI tools & skills, projects and contact.'
    : 'Vũ AI — người đam mê công nghệ. Blog, tool & skill AI, dự án và liên hệ.');
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL(image, site.url).href;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'vi_VN'} />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" type="application/rss+xml" title={site.name} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Nguyễn Ngọc Vũ',
      alternateName: 'Vũ AI',
      url: site.url,
      email: site.email,
      sameAs: Object.values(site.social),
    })} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
