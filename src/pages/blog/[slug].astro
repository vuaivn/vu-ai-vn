---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { categories as cats, site } from '@/config';
import { formatDate, readingTime } from '@/utils';
import { useTranslations } from '@/i18n/ui';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await post.render();
const lang = post.data.lang;
const t = useTranslations(lang);
const catName = cats[lang].find((c) => c.slug === post.data.category)?.name ?? post.data.category;
const mins = readingTime(post.body);
const cover = post.data.cover;
const canonical = new URL(`/blog/${post.slug}`, site.url).href;
const pub = post.data.pubDate.toISOString();
const upd = (post.data.updatedDate ?? post.data.pubDate).toISOString();

const jsonLd: any[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    inLanguage: lang,
    datePublished: pub,
    dateModified: upd,
    author: { '@type': 'Person', name: 'Nguyễn Ngọc Vũ', url: site.url },
    publisher: { '@type': 'Person', name: 'Vũ AI', url: site.url },
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    url: canonical,
    ...(cover ? { image: new URL(cover, site.url).href } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog', site.url).href },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: canonical },
    ],
  },
];
if (post.data.faq?.length) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: post.data.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}
---
<BaseLayout title={post.data.title} description={post.data.description} image={cover} type="article">
  <article class="article container">
    <div class="meta" style="color:var(--accent2);font-size:0.85rem;">{catName}</div>
    <h1>{post.data.title}</h1>
    <div class="article-meta">
      {formatDate(post.data.pubDate, lang)} · {mins} {t('blog.readingTime')}
    </div>
    {cover && (
      <img
        src={cover}
        alt={post.data.title}
        width="1200"
        height="675"
        loading="eager"
        style="width:100%;height:auto;border-radius:12px;margin:1rem 0 1.5rem;"
      />
    )}
    <div class="prose">
      <Content />
    </div>
  </article>
  {jsonLd.map((obj) => (
    <script type="application/ld+json" set:html={JSON.stringify(obj)} />
  ))}
</BaseLayout>
