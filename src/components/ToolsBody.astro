---
import { getLangFromUrl, useTranslations } from '@/i18n/ui';
import { tools, projects } from '@/config';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="section container">
  <div class="section-head">
    <div class="eyebrow">Tool & Skill</div>
    <h2>{t('tools.title')}</h2>
    <p>{t('tools.subtitle')}</p>
  </div>

  <h3 style="margin:10px 0 18px;font-size:1.3rem;">{t('tools.skillsHead')}</h3>
  <div class="grid grid-3">
    {tools.map((tool) => (
      <div class="card">
        <h3>{tool.name[lang]}</h3>
        <p>{tool.desc[lang]}</p>
        <div class="tags">{tool.tags.map((tg) => <span class="tag">{tg}</span>)}</div>
        {tool.link && <a class="link-arrow" href={tool.link}>{t('tools.visit')} →</a>}
      </div>
    ))}
  </div>

  <h3 id="projects" style="margin:44px 0 18px;font-size:1.3rem;">{t('tools.projectsHead')}</h3>
  <div class="grid grid-2">
    {projects.map((pj) => (
      <div class="card">
        <h3>{pj.name[lang]}</h3>
        <p>{pj.desc[lang]}</p>
        <div class="tags">{pj.tags.map((tg) => <span class="tag">{tg}</span>)}</div>
        {pj.link && <a class="link-arrow" href={pj.link} target="_blank" rel="noopener">{t('tools.visit')} →</a>}
      </div>
    ))}
  </div>
</section>
